{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "env": {
    "PREDICTION_LOG_GITHUB_REPO": "Jaymehta45/Sabermetric-IPL-Prediction-",
    "PREDICTION_LOG_GITHUB_BRANCH": "main"
  },
  "build": {
    "env": {
      "PREDICTION_LOG_GITHUB_REPO": "Jaymehta45/Sabermetric-IPL-Prediction-",
      "PREDICTION_LOG_GITHUB_BRANCH": "main"
    }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/history",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
